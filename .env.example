# ------------------------------------------------------------------------------
# Configuración de DocuSeal
# Copia este archivo a .env y ajusta los valores antes de levantar el servicio.
# ------------------------------------------------------------------------------

# ==============================
# Básico
# ==============================

# Puerto en el que escuchará DocuSeal en tu máquina local
APP_PORT=3000

# URL pública de la aplicación. Usada para generar enlaces de firma y webhooks.
# Ejemplo local: http://localhost:3000
# Ejemplo producción: https://firma.tuempresa.com
# Si usas Tailscale Funnel para compartir con clientes, cámbiala a tu URL pública:
#   HOST_URL=https://tu-nombre.tailnet-name.ts.net
HOST_URL=http://localhost:3000

# ==============================
# Base de datos (incluido en docker-compose.yml)
# ==============================
# La imagen Docker oficial de DocuSeal REQUIERE PostgreSQL.
# El docker-compose.yml ya incluye PostgreSQL 16; no es necesario modificar nada.
# DATABASE_URL=postgresql://docuseal:docuseal@postgres:5432/docuseal

# ==============================
# Almacenamiento de archivos (opcional)
# ==============================
# Si no configuras nada, los PDFs se guardan en disco local (carpeta /data).
# Para usar AWS S3, Google Cloud Storage o Azure, descomenta las variables
# correspondientes y rellena tus credenciales.

# AWS S3
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=mi-bucket-docuseal

# Google Cloud Storage
# GOOGLE_STORAGE_BUCKET=mi-bucket-docuseal
# (Asegúrate de montar la clave JSON como volumen si usas GCS)

# Azure Blob Storage
# AZURE_STORAGE_ACCOUNT_NAME=miaccount
# AZURE_STORAGE_ACCESS_KEY=...
# AZURE_STORAGE_CONTAINER=docuseal

# ==============================
# Email / SMTP (para notificaciones)
# ==============================
# DocuSeal envía emails a los firmantes. Configura tu servidor SMTP:
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_DOMAIN=tu-dominio.com
SMTP_USERNAME=tu-email@gmail.com
SMTP_PASSWORD=tu-app-password
SMTP_AUTHENTICATION=plain
SMTP_ENABLE_STARTTLS_AUTO=true
SMTP_FROM="DocuSeal <no-reply@tu-dominio.com>"

# ==============================
# Seguridad
# ==============================
# Cambia esto por una cadena aleatoria larga en producción.
# Se usa para firmar cookies y tokens internos.
# Genera una nueva con: openssl rand -base64 48
SECRET_KEY_BASE=change_me_in_production_use_a_256_bit_string
